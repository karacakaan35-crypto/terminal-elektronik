{
  "name": "fixboard-pro-diagnostics",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0",
    "build": "vite build",
    "build:sites": "vite build --mode sites",
    "lint": "oxlint",
    "test": "node --test",
    "validate:data": "node scripts/diagnostics-validator.mjs",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0",
    "serve:pin": "node scripts/pin-server.mjs",
    "serve:astra": "node scripts/astra-bridge.mjs",
    "ollama:serve": "/Applications/Ollama.app/Contents/Resources/ollama serve",
    "ollama:list": "/Applications/Ollama.app/Contents/Resources/ollama list",
    "ollama:pull:gemma4": "/Applications/Ollama.app/Contents/Resources/ollama pull gemma4:e2b-it-qat",
    "tunnel": "tools/cloudflared tunnel --protocol http2 --url http://127.0.0.1:4174"
  },
  "dependencies": {
    "autoprefixer": "^10.5.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.24.0",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1"
  }
}
